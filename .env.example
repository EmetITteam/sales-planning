# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# PostgreSQL (Supabase)
DATABASE_URL="postgresql://postgres.your-ref:password@pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres"

# API Security
API_SECRET_KEY="generate-a-random-32-char-string"

# 1C HTTP-сервіс (інтеграція через src/app/api/onec)
# Базовий URL handler-а в 1С (той самий що використовує CRM Мітинг)
ONEC_BASE_URL="https://1c.emet.com.ua/api/handler"
# Сервісний логін для Basic Auth (узгоджено з 1С-програмістом)
ONEC_LOGIN="service_account"
ONEC_PASSWORD="strong-password-here"
