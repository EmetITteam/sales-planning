# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# PostgreSQL (Supabase)
DATABASE_URL="postgresql://postgres.your-ref:password@pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres"

# API Security
API_SECRET_KEY="generate-a-random-32-char-string"

# 1C HTTP-сервіс (інтеграція через src/app/api/onec)
# Базовий URL handler-а в 1С (той самий що використовує CRM Мітинг)
ONEC_BASE_URL="https://1c.emet.com.ua/api/handler"
# Опційно: Basic Auth (тільки якщо HTTP-сервіс вимагає авторизацію).
# У EMET зараз 1С налаштований на анонімний доступ — лишити порожнім.
# ONEC_LOGIN="service_account"
# ONEC_PASSWORD="strong-password-here"

# Демо-кнопки швидкого входу на формі логіну (true/false).
# true — лишають моки + швидкі логіни для розробки.
# false — тільки реальний логін через 1С.
# ⚠️ ДЕФОЛТ "false" — якщо комусь треба для dev, явно встановити "true" локально.
# Раніше було "true" що при деплої без override = небезпечно (mock-users без пароля).
NEXT_PUBLIC_DEMO_LOGIN="false"

# Sprint 1.5: вмикає реальний API для /meetings замість моків.
# Поки false — UI працює з getMockMeetings (зворотна сумісність). Коли
# готова buffer-схема й worker — переключити на "true".
NEXT_PUBLIC_MEETINGS_USE_REAL_API="false"

# Sprint 1.5.3: cron-worker для buffer-sync meetings → 1С.
# CRON_SECRET — секрет для авторизації Vercel cron виклику до
# /api/cron/sync-meetings. Генеруй: openssl rand -hex 32  (або
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET="generate-a-random-64-char-string"
# DRY-RUN: коли "true" — worker лише логує payload без виклику 1С.
# Залишай "true" поки 1С dev не підтвердить що його actions готові приймати
# наші запити. Як перевірив — постав "false" щоб погнало реально.
MEETINGS_SYNC_DRY_RUN="true"
